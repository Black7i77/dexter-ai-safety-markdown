# Dexter website
DEXTER_HOST=127.0.0.1
DEXTER_PORT=5050

# Ollama must stay local. Do not point Cloudflare directly at port 11434.
OLLAMA_BASE_URL=http://127.0.0.1:11434
DEXTER_DEFAULT_MODEL=llama3.2:latest
OLLAMA_NUM_CTX=8192

# Turn this on only when requests reach Dexter through your Cloudflare Tunnel.
TRUST_CLOUDFLARE=false

# Public beta controls
PUBLIC_BETA=true
ENABLE_PUBLIC_CHAT=true
# Leave blank for an open beta. Set a private code for invited testers.
BETA_ACCESS_CODE=
# Optional comma-separated hostnames after your permanent domain is connected.
ALLOWED_HOSTS=

# Simple application-level protection. Cloudflare rules can add another layer.
RATE_LIMIT_REQUESTS=12
RATE_LIMIT_WINDOW_SECONDS=300
MAX_CONCURRENT_GLOBAL=3
MAX_CONCURRENT_PER_IP=1

# Conversation limits sent to the local model.
MAX_HISTORY_MESSAGES=32
MAX_MESSAGE_CHARS=8000
MAX_TOTAL_CHARS=48000

# Project ZIP export safety limits
MAX_EXPORT_FILES=40
MAX_EXPORT_CHARS=500000
