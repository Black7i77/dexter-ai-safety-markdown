# Dexter website
DEXTER_HOST=127.0.0.1
DEXTER_PORT=5050

# Ollama must stay local. Do not point Cloudflare directly at port 11434.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Current lightweight local reasoning model.
DEXTER_DEFAULT_MODEL=qwen3:1.7b
DEXTER_SMART_MODEL=qwen3:1.7b

# 8K is a practical context for the lightweight model and a 16 GB laptop.
OLLAMA_NUM_CTX=8192
DEXTER_ENABLE_THINKING=true
DEXTER_THINK_LEVEL=high

# Optional current-information verification through Ollama Web Search.
# This is disabled by default. It requires a free Ollama account and server-side API key.
DEXTER_WEB_SEARCH=false
OLLAMA_API_KEY=
DEXTER_WEB_SEARCH_MAX_RESULTS=5
DEXTER_WEB_SEARCH_TIMEOUT=20

# Turn this on only when requests reach Dexter through your Cloudflare Tunnel.
TRUST_CLOUDFLARE=false

# Public beta controls
PUBLIC_BETA=true
ENABLE_PUBLIC_CHAT=true
BETA_ACCESS_CODE=
ALLOWED_HOSTS=

# Simple application-level protection. Cloudflare rules can add another layer.
RATE_LIMIT_REQUESTS=12
RATE_LIMIT_WINDOW_SECONDS=300
MAX_CONCURRENT_GLOBAL=3
MAX_CONCURRENT_PER_IP=1

# Conversation limits sent to the local model.
MAX_HISTORY_MESSAGES=32
MAX_MESSAGE_CHARS=8000
MAX_TOTAL_CHARS=48000

# Project ZIP export safety limits
MAX_EXPORT_FILES=40
MAX_EXPORT_CHARS=500000

# Free, keyless source lookup for factual questions.
DEXTER_FREE_WEB_SEARCH=true
DEXTER_FACT_CHECK=true
DEXTER_FACT_CHECK_MIN_SOURCES=2
DEXTER_FACT_CHECK_MAX_RESULTS=6
DEXTER_FACT_CHECK_CACHE_SECONDS=900
DEXTER_FACT_CHECK_MAX_ANSWER_CHARS=7000

# Lock high-stakes current facts to deterministic backend evidence.
# The language model cannot overturn confirmed source consensus.
DEXTER_LOCK_CURRENT_FACTS=true
